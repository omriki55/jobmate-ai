# ── Required ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Security ─────────────────────────────────────────────
SECRET_KEY=               # Auto-generated if empty; set a stable value in production
ENVIRONMENT=dev           # dev | production
CORS_ORIGINS=*            # Comma-separated origins, e.g. https://jobmate.example.com

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./jobmate.db
# Production: postgresql+asyncpg://user:pass@host:5432/jobmate

# ── Upload ───────────────────────────────────────────────
MAX_UPLOAD_MB=10

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ── App defaults ─────────────────────────────────────────
CHECKIN_HOUR=8            # Daily check-in hour (UTC, 0-23)
MATCH_THRESHOLD=50        # Minimum match score to surface a job
DAILY_APPLY_LIMIT=10      # Max auto-applies per user per day
